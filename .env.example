# ==================== PostgreSQL Connection ====================
# PostgreSQL database connection details
# Can use local PostgreSQL or cloud service (ElephantSQL, Render, Heroku, etc.)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=your_password

# ==================== Server Configuration ====================
# Port number for the backend server (default: 5000)
PORT=5000

# Node environment (production or development)
NODE_ENV=development

# ==================== CORS Configuration ====================
# Frontend URL for CORS (adjust based on your deployment)
FRONTEND_URL=http://localhost:3000
